# Copy this to .env.local for local development
# On Vercel: add these under Project → Settings → Environment Variables

# Your deployed SovereignAgent contract address (fill after forge deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x

# Ritual Chain RPC (public — fine to expose)
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org

# ─── Foundry deploy vars (NEVER commit, use Vercel env or .env.local) ──────
# PRIVATE_KEY=0x...
# AGENT_PROMPT=Monitor Ritual Chain and post a block digest every 50 blocks
# WAKE_DELAY=50
